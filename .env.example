# Supabase (same project as other Print Room apps)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Image Generator API (pr-image-generator Vercel deployment)
IMAGE_GENERATOR_API_URL=https://pr-image-generator.vercel.app
INTERNAL_API_KEY=your-shared-api-key

# Quote Tool (embeds the design tool in an iframe)
NEXT_PUBLIC_DESIGN_TOOL_URL=https://print-room-studio.vercel.app
NEXT_PUBLIC_APP_URL=https://your-staff-portal-domain.vercel.app
STAFF_QUOTE_SECRET=your-shared-jwt-secret
